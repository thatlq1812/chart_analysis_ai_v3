# ============================================================================
# Data Directories (Keep structure, ignore content)
# ============================================================================
data/raw/*
!data/raw/.gitkeep

data/processed/*
!data/processed/.gitkeep

data/cache/*
!data/cache/.gitkeep

data/training/*
!data/training/.gitkeep

data/samples/*
!data/samples/.gitkeep

# ============================================================================
