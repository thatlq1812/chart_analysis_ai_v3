# ============================================================================
models/weights/*.pt
models/weights/*.pth
models/weights/*.onnx
models/weights/*.bin
!models/weights/.gitkeep

# ============================================================================
# Output Directories
# ============================================================================
output/*
!output/.gitkeep

logs/*
!logs/.gitkeep

# ============================================================================
# Jupyter Notebooks
# ============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# ============================================================================
# Environment & Secrets
# ============================================================================
.env
.env.local
.env.*.local
config/secrets/*
!config/secrets/.gitkeep

# ============================================================================
