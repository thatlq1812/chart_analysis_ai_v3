# =============================================================================
# Geo-SLM Chart Analysis - Environment Variables Template
# Copy this file to .env and fill in the actual values.
# NEVER commit .env to version control.
# =============================================================================


# =============================================================================
# AI Provider API Keys
# =============================================================================

# Google Gemini API key (Stage 4 fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API key (Stage 4 second fallback)
OPENAI_API_KEY=your_openai_api_key_here


# =============================================================================
# API Server Settings (prefix: API_)
# All have usable defaults; override only what you need.
# =============================================================================

# Bind address and port
API_HOST=0.0.0.0
API_PORT=8000

# Number of uvicorn workers (production: match CPU cores)
API_WORKERS=2

# Enable hot-reload (development only, NEVER in production)
API_RELOAD=false

# Enable debug mode (verbose error responses)
API_DEBUG=false

# CORS allowed origins (comma-separated list or JSON array)
# Development: allow localhost frontends
# Production: replace with your domain(s)
API_CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Maximum file upload size in megabytes
API_MAX_UPLOAD_SIZE_MB=50

# Data directories (relative to working directory)
API_DATA_DIR=data
API_UPLOAD_DIR=data/uploads
API_OUTPUT_DIR=data/processed

# Default pipeline settings for API requests
API_DEFAULT_PDF_DPI=150
API_DEFAULT_EXTRACT_CONTEXT=true

# Job record time-to-live in seconds (default: 24 hours)
API_JOB_TTL_SECONDS=86400


# =============================================================================
# Task Queue (Celery + Redis)
# Required only when API_CELERY_ENABLED=true
# =============================================================================

# Redis connection URL
API_REDIS_URL=redis://localhost:6379/0

# Enable Celery async task queue
# false = BackgroundTasks (in-process, no Redis needed, dev/single-instance)
# true  = Celery workers (multi-process/multi-node, production)
API_CELERY_ENABLED=false


# =============================================================================
# Database (for job persistence - future Phase 3)
# =============================================================================

# SQLAlchemy connection string
# Development: SQLite (no server needed)
DATABASE_URL=sqlite+aiosqlite:///data/db.sqlite3

# Production: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chart_analysis
